# PSL Railway - Environment Variables Template
# Copy to .env and fill in values. Never commit .env to version control.

# Required
ENVIRONMENT=production
JWT_SECRET_KEY=  # Generate: python scripts/generate_secrets.py
DATABASE_URL=   # Auto-set by Railway PostgreSQL, or set manually
CORS_ORIGINS=   # Comma-separated frontend origins, e.g. https://yourdomain.com

# Optional
PORT=8000
LOG_LEVEL=INFO
MODEL_STORAGE_PATH=/data/models

# Twitter API (optional) - for Fan Zone tweets from @OfficialPSL
TWITTER_BEARER_TOKEN=
